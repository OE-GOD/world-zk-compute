# =============================================================================
# World ZK Compute -- Sepolia Testnet Environment Variables
#
# Copy to .env.sepolia and fill in values:
#   cp .env.sepolia.example .env.sepolia
#
# Usage with docker compose:
#   docker compose -f docker-compose.sepolia.yml --env-file .env.sepolia up -d
#
# Usage with deploy script:
#   source .env.sepolia && ./scripts/deploy-sepolia-tee.sh
# =============================================================================

# --- RPC ---
# Alchemy/Infura Sepolia endpoint (public RPC may rate-limit)
ALCHEMY_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Alias used by operator service and deploy scripts
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# --- Private Keys ---
# NEVER commit real keys. Each should have ~0.06 ETH on Sepolia.
# Deployer: deploys contracts, registers programs/enclaves, admin role
DEPLOYER_PRIVATE_KEY=0x_YOUR_DEPLOYER_PRIVATE_KEY

# Enclave: signs TEE attestations (keep isolated from other roles)
ENCLAVE_PRIVATE_KEY=0x_YOUR_ENCLAVE_PRIVATE_KEY

# Operator: watches chain, submits TEE results, triggers disputes
OPERATOR_PRIVATE_KEY=0x_YOUR_OPERATOR_PRIVATE_KEY

# Prover: submits ZK proofs (optional, only needed for ZK dispute path)
PROVER_PRIVATE_KEY=0x_YOUR_PROVER_PRIVATE_KEY

# Requester: submits execution requests (can be same as deployer for testing)
REQUESTER_PRIVATE_KEY=0x_YOUR_REQUESTER_PRIVATE_KEY

# --- Contract Addresses (filled after deploy-sepolia-tee.sh) ---
PROGRAM_REGISTRY_ADDRESS=
TEE_VERIFIER_ADDRESS=
EXECUTION_ENGINE_ADDRESS=

# --- Verification Router (pre-deployed by risc0 on Sepolia) ---
VERIFIER_ROUTER_ADDRESS=0x925d8331ddc0a1F0d96E68CF073DFE1d92b69187

# --- Program Registration ---
# XGBoost rule-engine image ID (risc0 v3.0, serde-free)
PROGRAM_IMAGE_ID=0xf85c194e1a8e2c2e38746c6d81c7ac9ddf25848a8dfc049db7f4725b3ab56e33

# --- Enclave Config ---
# Model hash for TEE attestation verification (optional, validates loaded model)
ENCLAVE_MODEL_HASH=
# Enclave server port (default: 8080)
# PORT=8080
# Model format: auto, xgboost, or lightgbm (default: auto)
# MODEL_FORMAT=auto
# Enable AWS Nitro attestation (default: false for local dev)
# NITRO_ENABLED=false
# Rate limit: max inference requests per minute (default: 60)
# MAX_REQUESTS_PER_MINUTE=60

# --- Operator Config ---
# Polling interval for new execution requests (seconds)
OPERATOR_POLL_INTERVAL=12
# Stake amount in wei for submitting results (default: 100000000000000 = 0.0001 ETH)
# PROVER_STAKE=100000000000000
# Auto-dispute: whether operator should auto-challenge suspicious results
OPERATOR_AUTO_DISPUTE=false
# Enable Nitro attestation verification (default: false)
# NITRO_VERIFICATION=false
# Max retries for proof generation (default: 3)
# MAX_PROOF_RETRIES=3
# Webhook URL for dispute/alert notifications (optional)
# WEBHOOK_URL=https://hooks.slack.com/services/...
# Dry-run mode — log actions without sending transactions (default: false)
# DRY_RUN=false

# --- Etherscan Verification ---
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# --- Logging ---
RUST_LOG=info
# RUST_LOG_FORMAT=json

# --- Chain ---
CHAIN_ID=11155111
