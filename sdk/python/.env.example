# World ZK Compute Python SDK Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and should never be committed.

# JSON-RPC endpoint for your target chain
# Examples:
#   Local Anvil:      http://127.0.0.1:8545
#   Sepolia:          https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
#   World Chain:      https://worldchain-sepolia.g.alchemy.com/v2/YOUR_KEY
#   Arbitrum Sepolia: https://sepolia-rollup.arbitrum.io/rpc
RPC_URL=https://worldchain-sepolia.g.alchemy.com/v2/YOUR_KEY

# Indexer service URL (used by the SDK client for request listing/status)
INDEXER_URL=http://localhost:8081

# Private key for signing transactions (hex-encoded, with 0x prefix)
# WARNING: Never commit real private keys. Use a dedicated test wallet.
PRIVATE_KEY=0x...your_private_key_here

# Deployed contract address (TEEMLVerifier or RemainderVerifier)
CONTRACT_ADDRESS=0x...deployed_contract_address

# Chain ID for the target network
#   31337  = localhost (Anvil)
#   11155111 = Ethereum Sepolia
#   421614 = Arbitrum Sepolia
#   4801   = World Chain Sepolia
CHAIN_ID=4801

# --- Sepolia Integration Tests ---
# These are used by tests/test_sepolia_integration.py
# ALCHEMY_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# TEE_VERIFIER_ADDRESS=0x...deployed_tee_verifier
