# World ZK Compute Configuration
# Copy this file to .env and customize:  cp .env.example .env
# WARNING: Never commit .env to version control.

# ── RPC / Network ────────────────────────────────────────────────────────────
# For testnet deployment:
RPC_URL=https://worldchain-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# For local Docker Compose (used internally by services):
OPERATOR_RPC_URL=http://anvil:8545

# ── Keys ─────────────────────────────────────────────────────────────────────
# Deployer / admin private key
PRIVATE_KEY=0x...
# Docker Compose uses these Anvil default keys for local dev:
DEPLOYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ENCLAVE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Contract Addresses (fill after deployment) ──────────────────────────────
REGISTRY_ADDRESS=0x...
VERIFIER_ADDRESS=0x...
ENGINE_ADDRESS=0x...
FEE_RECIPIENT=0x...
# Required by operator — address of the TEEMLVerifier contract:
TEE_VERIFIER_ADDRESS=0x...
# Optional: comma-separated list of additional contract addresses to watch
# CONTRACT_ADDRESSES=0xaaa...,0xbbb...

# ── Operator Service ────────────────────────────────────────────────────────
ENCLAVE_URL=http://enclave:8080
PROVER_URL=http://warm-prover:3000
MODEL_PATH=/app/model/model.json
PROOFS_DIR=/app/proofs
PRECOMPUTE_BIN=/usr/local/bin/precompute_proof
METRICS_PORT=9090
# Stake amount in wei for submitting results (default: 100000000000000 = 0.0001 ETH)
# PROVER_STAKE=100000000000000
# Enable Nitro attestation verification (default: false)
# NITRO_VERIFICATION=false
# Expected PCR0 hash for Nitro enclaves (required when NITRO_VERIFICATION=true)
# EXPECTED_PCR0=
# Attestation cache TTL in seconds (default: 300)
# ATTESTATION_CACHE_TTL=300
# Max retries for proof generation (default: 3)
# MAX_PROOF_RETRIES=3
# Delay between proof retries in seconds (default: 5)
# PROOF_RETRY_DELAY_SECS=5
# Webhook URL for dispute/alert notifications (optional)
# WEBHOOK_URL=https://hooks.slack.com/services/...
# Dry-run mode — log actions without sending transactions (default: false)
# DRY_RUN=false
# Path to operator state file for persistence across restarts
# STATE_FILE=/app/state.json

# ── Enclave ─────────────────────────────────────────────────────────────────
PORT=8080
# Model format: auto, xgboost, or lightgbm (default: auto)
# MODEL_FORMAT=auto
# Enable AWS Nitro attestation (default: false for local dev)
# NITRO_ENABLED=false
# Chain ID for replay protection (default: 1 = mainnet)
# CHAIN_ID=1
# Admin API key for hot-reload and management endpoints (optional)
# ADMIN_API_KEY=
# Expected model SHA-256 hash for integrity validation (optional)
# EXPECTED_MODEL_HASH=
# Enable health watchdog (default: true)
# WATCHDOG_ENABLED=true
# Rate limit: max inference requests per minute (default: 60)
# MAX_REQUESTS_PER_MINUTE=60

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info
RUST_LOG_FORMAT=json
# OpenTelemetry distributed tracing (optional)
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=worldzk-operator
# LOG_LEVEL=info

# ── Prover ──────────────────────────────────────────────────────────────────
MIN_TIP=0.0001
POLL_INTERVAL=5

# ── Etherscan ───────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=...
