{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Sepolia Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Sepolia Block Number",
      "type": "stat",
      "targets": [
        {
          "expr": "ethereum_block_number{chain=\"sepolia\"}",
          "legendFormat": "Block"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "TEE Results Submitted",
      "type": "stat",
      "targets": [
        {
          "expr": "tee_results_submitted_total{chain=\"sepolia\"}",
          "legendFormat": "Submitted"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Disputes",
      "type": "stat",
      "targets": [
        {
          "expr": "tee_disputes_active{chain=\"sepolia\"}",
          "legendFormat": "Disputes"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Operator Errors",
      "type": "stat",
      "targets": [
        {
          "expr": "operator_errors_total{chain=\"sepolia\"}",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Wallet Balances",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ETH",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "green", "value": 0.05 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Deployer Balance",
      "type": "stat",
      "targets": [
        {
          "expr": "wallet_balance_eth{role=\"deployer\",chain=\"sepolia\"}",
          "legendFormat": "Deployer"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ETH",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "green", "value": 0.05 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 6 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Operator Balance",
      "type": "stat",
      "targets": [
        {
          "expr": "wallet_balance_eth{role=\"operator\",chain=\"sepolia\"}",
          "legendFormat": "Operator"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ETH",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "green", "value": 0.05 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 6 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Enclave Balance",
      "type": "stat",
      "targets": [
        {
          "expr": "wallet_balance_eth{role=\"enclave\",chain=\"sepolia\"}",
          "legendFormat": "Enclave"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 300,
      "title": "Transaction Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 8,
      "title": "Transactions per Minute",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(operator_transactions_total{chain=\"sepolia\"}[5m]) * 60",
          "legendFormat": "Tx/min"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "gas"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 9,
      "title": "Gas Used per Transaction",
      "type": "timeseries",
      "targets": [
        {
          "expr": "operator_gas_used{chain=\"sepolia\"}",
          "legendFormat": "Gas"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 400,
      "title": "Enclave Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 10,
      "title": "Inference Latency (P95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(enclave_inference_duration_seconds_bucket{chain=\"sepolia\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(enclave_inference_duration_seconds_bucket{chain=\"sepolia\"}[5m]))",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 11,
      "title": "Inference Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(enclave_inference_requests_total{chain=\"sepolia\"}[5m])",
          "legendFormat": "req/s"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["worldzk", "sepolia", "tee"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "World ZK Compute - Sepolia",
  "uid": "worldzk-sepolia"
}
