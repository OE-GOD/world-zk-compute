app = "worldzk-verifier"
primary_region = "iad"

[build]
  dockerfile = "Dockerfile"
  build_target = ""

[env]
  PORT = "3000"
  RUST_LOG = "info"
  RATE_LIMIT_RPM = "60"

[http_service]
  internal_port = 3000
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 1

  [http_service.concurrency]
    type = "requests"
    hard_limit = 100
    soft_limit = 80

[[http_service.checks]]
  grace_period = "10s"
  interval = "30s"
  method = "GET"
  path = "/health"
  timeout = "5s"

[[vm]]
  memory = "1gb"
  cpu_kind = "shared"
  cpus = 1
