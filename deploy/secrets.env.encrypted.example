# =============================================================================
# World ZK Compute -- SOPS-Encrypted Secrets (EXAMPLE)
#
# This file shows what a SOPS-encrypted .env file looks like.
# Real encrypted files have each VALUE replaced with a SOPS ciphertext blob.
# Keys (variable names) remain in plaintext for readability.
#
# How to create a real encrypted env file:
#
#   1. Copy and fill in plaintext values:
#      cp deploy/production.env.example deploy/secrets.env
#      vim deploy/secrets.env
#
#   2. Configure .sops.yaml at the repo root with your age/KMS recipients
#
#   3. Encrypt:
#      sops encrypt deploy/secrets.env > deploy/secrets.env.encrypted
#      rm deploy/secrets.env
#
#   4. Commit the encrypted file (safe to commit -- values are ciphertext):
#      git add deploy/secrets.env.encrypted
#
# How to decrypt:
#
#   sops decrypt deploy/secrets.env.encrypted > /tmp/.env
#   docker compose --env-file /tmp/.env up -d
#   rm /tmp/.env
#
# How to edit:
#
#   sops deploy/secrets.env.encrypted
#   # Opens in $EDITOR, saves re-encrypted on exit
#
# See docs/SECRETS.md for full documentation.
# =============================================================================

# Below is an approximation of SOPS dotenv output format.
# In real SOPS output, each value is an encrypted blob and there is
# a "sops" metadata block appended at the end.

# === Tier 1: Critical (use multisig in production) ===
# ADMIN_PRIVATE_KEY is only needed for deploy scripts and admin-cli.
# In production the contract owner should be a Gnosis Safe multisig,
# not a single EOA.
ADMIN_PRIVATE_KEY=ENC[AES256_GCM,data:abc123...,iv:def456...,tag:ghi789...,type:str]

# === Tier 2: High (store in HSM/KMS for production) ===
OPERATOR_PRIVATE_KEY=ENC[AES256_GCM,data:jkl012...,iv:mno345...,tag:pqr678...,type:str]
ENCLAVE_PRIVATE_KEY=ENC[AES256_GCM,data:stu901...,iv:vwx234...,tag:yza567...,type:str]

# === Tier 3: Medium ===
REGISTRY_SIGNING_KEY=ENC[AES256_GCM,data:bcd890...,iv:efg123...,tag:hij456...,type:str]
RPC_URL=ENC[AES256_GCM,data:klm789...,iv:nop012...,tag:qrs345...,type:str]

# === Tier 4: Low ===
GATEWAY_API_KEYS=ENC[AES256_GCM,data:tuv678...,iv:wxy901...,tag:zab234...,type:str]
VERIFIER_API_KEYS=ENC[AES256_GCM,data:cde567...,iv:fgh890...,tag:ijk123...,type:str]
ADMIN_API_KEY=ENC[AES256_GCM,data:lmn456...,iv:opq789...,tag:rst012...,type:str]
GRAFANA_PASSWORD=ENC[AES256_GCM,data:uvw345...,iv:xyz678...,tag:abc901...,type:str]

# === Non-secret configuration (not encrypted) ===
CHAIN_ID=42161
OPERATOR_POLL_INTERVAL=12
OPERATOR_AUTO_DISPUTE=true
NITRO_VERIFICATION=true
RATE_LIMIT_RPM=100
RUST_LOG=info

# === Contract addresses (not secret, but deployment-specific) ===
TEE_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
EXECUTION_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
PROGRAM_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# === Alerting (webhook URL is sensitive) ===
ALERT_CONFIG_JSON=ENC[AES256_GCM,data:def234...,iv:ghi567...,tag:jkl890...,type:str]

# =============================================================================
# SOPS metadata (appended automatically by sops encrypt)
# =============================================================================
# sops_version=3.9.0
# sops_age__list_0__map_recipient=age1abc123def456ghi789jkl012mno345pqr678stu901
# sops_age__list_0__map_enc=-----BEGIN AGE ENCRYPTED FILE-----\n...\n-----END AGE ENCRYPTED FILE-----
# sops_lastmodified=2026-03-26T00:00:00Z
# sops_mac=ENC[AES256_GCM,data:...,iv:...,tag:...,type:str]
