# =============================================================================
# World ZK Compute -- Production Environment Variables
#
# Copy to .env.production and fill in values:
#   cp deploy/production.env.example .env.production
#   chmod 600 .env.production
#
# Usage:
#   docker compose -f docker-compose.production.yml --env-file .env.production up -d
#
# NEVER commit .env.production to version control.
# =============================================================================

# === Required ================================================================

# Ethereum JSON-RPC URL (Arbitrum One, Sepolia, or other target chain)
RPC_URL=https://arb1.arbitrum.io/rpc

# Operator wallet private key (hex, with 0x prefix)
# The operator watches for disputes and submits proofs/results on-chain.
OPERATOR_PRIVATE_KEY=0x...

# Enclave signer private key (hex, with 0x prefix)
# The enclave uses this key to sign TEE attestations.
ENCLAVE_PRIVATE_KEY=0x...

# TEEMLVerifier contract address (deployed on target chain)
TEE_VERIFIER_ADDRESS=0x...

# === Contract Addresses (optional, depends on deployment) ====================

# ExecutionEngine contract address
EXECUTION_ENGINE_ADDRESS=0x...

# ProgramRegistry contract address
PROGRAM_REGISTRY_ADDRESS=0x...

# === Chain Configuration =====================================================

# Chain ID (42161 = Arbitrum One, 421614 = Arbitrum Sepolia, 11155111 = Sepolia)
CHAIN_ID=42161

# === Service Configuration ===================================================

# Operator polling interval for new events (seconds)
OPERATOR_POLL_INTERVAL=12

# Auto-dispute: operator automatically challenges suspicious results
OPERATOR_AUTO_DISPUTE=true

# AWS Nitro attestation verification (enable in production with Nitro enclaves)
NITRO_VERIFICATION=false

# Expected PCR0 for strict enclave identity (hex string, optional)
# EXPECTED_PCR0=

# Verifier API rate limit (requests per minute)
RATE_LIMIT_RPM=100

# Indexer polling interval (seconds)
INDEXER_POLL_INTERVAL=12

# Indexer per-IP rate limit (requests per minute)
INDEXER_RATE_LIMIT=100

# Enclave inference rate limit (requests per minute)
ENCLAVE_RATE_LIMIT=60

# === Alerting (optional) =====================================================

# AlertManager config JSON for multi-channel alerting
# Channel types: slack_webhook, pagerduty, email, generic_webhook
#
# Example (Slack only):
# ALERT_CONFIG_JSON={"channels":[{"type":"slack_webhook","url":"https://hooks.slack.com/services/T00/B00/xxx","channel":"#alerts"}]}
#
# Example (Slack + PagerDuty):
# ALERT_CONFIG_JSON={"channels":[{"type":"slack_webhook","url":"https://hooks.slack.com/services/T00/B00/xxx","channel":"#alerts"},{"type":"pagerduty","routing_key":"YOUR_PD_ROUTING_KEY","service_name":"world-zk-operator"}]}
ALERT_CONFIG_JSON=

# === Port Mapping (override defaults if needed) ==============================

# VERIFIER_PORT=3000
# ENCLAVE_PORT=8080
# OPERATOR_PORT=9090
# INDEXER_PORT=8081
# PROVER_PORT=3002
# PRIVATE_INPUT_PORT=3003
# PROMETHEUS_PORT=9091
# GRAFANA_PORT=3001

# === Monitoring ==============================================================

# Grafana admin password (change from default in production!)
GRAFANA_PASSWORD=admin

# === Logging =================================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info
