# World ZK Compute Operator -- Environment Variables
#
# Copy to /etc/worldzk/operator.env and fill in real values.
# Restrict permissions:  chmod 600 /etc/worldzk/operator.env
#
# All variables here override values in the TOML config file.
# See services/operator/config.example.toml for full documentation.

# -- Required ----------------------------------------------------------

# Ethereum JSON-RPC URL (e.g., Alchemy, Infura, or a local node)
OPERATOR_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# Operator wallet private key (hex, with 0x prefix)
OPERATOR_PRIVATE_KEY=0x...

# TEEMLVerifier contract address
TEE_VERIFIER_ADDRESS=0x...

# -- Optional ----------------------------------------------------------

# TEE enclave HTTP endpoint
ENCLAVE_URL=http://localhost:8080

# Warm prover HTTP endpoint (omit to use local precompute binary)
# PROVER_URL=http://localhost:3000

# Port for the health/metrics HTTP server
METRICS_PORT=9090

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Dry-run mode: log actions without submitting transactions
# DRY_RUN=false

# Path to XGBoost model JSON file
# MODEL_PATH=./model.json

# Directory for storing pre-computed proofs
# PROOFS_DIR=./proofs

# Path to the precompute_proof binary
# PRECOMPUTE_BIN=precompute_proof

# AWS Nitro attestation verification (true/false)
# NITRO_VERIFICATION=false

# Expected PCR0 value for strict enclave identity (hex string)
# EXPECTED_PCR0=aabbccdd...

# Attestation cache TTL in seconds
# ATTESTATION_CACHE_TTL=300
